<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>KalorieCompass PRO</title>
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="KalorieCompass">
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; padding: 15px; padding-top: calc(15px + env(safe-area-inset-top)); background: #121212; color: #ffffff; max-width: 500px; margin: auto; box-sizing: border-box; }
        .dashboard { background: #1e272e; color: white; padding: 20px; border-radius: 15px; text-align: center; margin-bottom: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
        .card { background: #2f3640; padding: 15px; margin-bottom: 15px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.2); }
        h1, h2, h3 { margin-top: 0; color: #4cd137; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 10px 0; }
        .btn { padding: 12px; border: none; border-radius: 8px; cursor: pointer; width: 100%; font-weight: bold; font-size: 0.95rem; background: #4cd137; color: #121212; transition: 0.2s; }
        .btn:active { background: #44bd32; }
        .btn-orange { background: #e1b12c; color: #121212; }
        .btn-blue { background: #00a8ff; color: white; }
        input, select { width: 100%; padding: 10px; margin: 5px 0; border-radius: 6px; border: 1px solid #718093; background: #121212; color: white; box-sizing: border-box; }
        .progress-bar { background: #718093; border-radius: 10px; height: 15px; overflow: hidden; margin: 10px 0; }
        .progress-fill { background: #4cd137; height: 100%; width: 0%; transition: width 0.3s; }
        .badge { background: #e1b12c; color: #121212; padding: 3px 8px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; display: inline-block; }
        .water-flex { display: flex; justify-content: space-between; margin-top: 10px; }
        .water-bottle { font-size: 2rem; cursor: pointer; opacity: 0.3; transition: 0.2s; }
        .water-bottle.active { opacity: 1; transform: scale(1.1); }
        .preview-box { display: none; margin-top: 10px; text-align: center; }
        .preview-img { max-width: 100%; max-height: 180px; border-radius: 8px; border: 1px solid #718093; }
        #coachSpeech { background: #121212; border-left: 4px solid #e1b12c; padding: 10px; border-radius: 4px; margin-top: 10px; font-style: italic; font-size: 0.9rem; }
        .search-results { background: #121212; border-radius: 6px; max-height: 200px; overflow-y: auto; margin-top: 5px; }
        .search-item { padding: 10px; border-bottom: 1px solid #2f3640; cursor: pointer; font-size: 0.9rem; }
        .search-item:hover { background: #2f3640; }
    </style>
</head>
<body>

<div class="dashboard">
    <div style="display:flex; justify-content: space-between; align-items: center;">
        <span id="langBadge" class="badge">DK</span>
        <span id="offlineBadge" class="badge" style="background:#4cd137; color:#121212;">⚡ LOKAL APP MODUS</span>
    </div>
    <h1 style="margin:10px 0 5px 0;">KalorieCompass</h1>
    <p style="margin:0; opacity:0.8;">Budget: <span id="budgetDisplay">1537</span> kcal | Tilbage: <span id="leftDisplay">1537</span> kcal</p>
    <h2 style="font-size: 2.2rem; margin: 10px 0; color:#fff;"><span id="totalKcal">0</span> <span style="font-size:1rem; opacity:0.5;">kcal</span></h2>
    <div class="progress-bar"><div id="progressBar" class="progress-fill"></div></div>
    <div id="fastingTimer" style="font-weight:bold; color:#e1b12c;">Faste (16:8): <span id="timer">Klar</span></div>
</div>

<div class="card">
    <h3>🌐 Global Varesøgning (Offline Kartotek)</h3>
    <input type="text" id="globalSearchInput" placeholder="Søg: f.eks. Skyr, Kylling, Coca-Cola..." oninput="searchOfflineFood()">
    <div id="searchResults" class="search-results"></div>
    
    <div id="weightFactorBox" style="display:none; margin-top:10px; background:#121212; padding:10px; border-radius:6px;">
        <p id="selectedFoodName" style="margin:0 0 5px 0; font-weight:bold; color:#4cd137;"></p>
        <p style="margin:0 0 10px 0; font-size:0.85rem; opacity:0.7;"><span id="selectedFoodKcal">0</span> kcal per 100g</p>
        <input type="number" id="foodAmountInput" placeholder="Hvor mange gram? (f.eks. 150)" inputmode="numeric">
        <button class="btn btn-blue" style="margin-top:5px;" onclick="logOfflineFood()">Tilføj til min dagslog</button>
    </div>
</div>

<div class="card">
    <h3>✍️ Manuel Indtastning</h3>
    <input type="text" id="manualName" placeholder="Varenavn (f.eks. Hjemmelavet lasagne)">
    <div class="grid">
        <input type="number" id="manualKcal" placeholder="Kalorier (kcal)" inputmode="numeric">
        <input type="number" id="manualWeight" placeholder="Vægt (g)" inputmode="numeric">
    </div>
    <button class="btn" onclick="logManualFood()">Gem og log vare</button>
</div>

<div class="card">
    <h3>📸 Coach & Offline AI Madscanner</h3>
    <div style="border:2px dashed #718093; padding:15px; text-align:center; border-radius:8px; margin-bottom:10px;">
        <label style="cursor:pointer; display:block;">
            📷 Tag/Vælg billede offline<br><span style="font-size:0.8rem; opacity:0.6;">Scanner lokalt baseret på hånd-reference</span>
            <input type="file" accept="image/*" style="display:none;" onchange="triggerLocalAIScan(event)">
        </label>
    </div>
    
    <div id="previewContainer" class="preview-box">
        <img id="scannedImagePreview" class="preview-img" src="" alt="Mad preview">
    </div>

    <select id="coachPersona" onchange="updateCoachTone()">
        <option value="ven">Bedste Ven (Mild)</option>
        <option value="militær">Militær-træner (Kontant)</option>
    </select>
    <div id="coachSpeech">Tag et billede eller søg for offline-coaching...</div>
</div>

<div class="card">
    <h3>Dagens Aktivitet & Vand</h3>
    <div class="grid">
        <button class="btn btn-orange" onclick="addSteps(5000)">+5.000 skridt</button>
        <button class="btn btn-orange" onclick="addSteps(10000)">+10.000 skridt</button>
    </div>
    <p style="margin:5px 0;">Stjerner optjent: <strong id="starDisplay" style="color:#e1b12c;">0 ⭐</strong></p>
    
    <div class="water-flex">
        <span class="water-bottle" id="w1" onclick="toggleWater(1)">🍼</span>
        <span class="water-bottle" id="w2" onclick="toggleWater(2)">🍼</span>
        <span class="water-bottle" id="w3" onclick="toggleWater(3)">🍼</span>
        <span class="water-bottle" id="w4" onclick="toggleWater(4)">🍼</span>
    </div>
</div>

<div class="card">
    <h3>Profil & Beregninger (Mifflin)</h3>
    <div class="grid">
        <input type="number" id="profAge" placeholder="Alder" value="32">
        <input type="number" id="profHeight" placeholder="Højde (cm)" value="180">
    </div>
    <input type="number" id="profWeight" placeholder="Vægt (kg)" value="80" oninput="syncWeightInput()">
    <button class="btn" onclick="runMifflin()">Genberegn Budget</button>
</div>

<div class="card">
    <h3>Vægt-historik mod mållinje (63 kg)</h3>
    <canvas id="weightChart" style="width:100%; height:180px;"></canvas>
</div>

<script>
    const offlineFoodDatabase = [
        { name: "Skyr (Naturel)", kcal: 63, brand: "Arla" },
        { name: "Kyllingebryst (Stegt)", kcal: 165, brand: "Global Standard" },
        { name: "Hakket Oksekød 4-7%", kcal: 125, brand: "Slagter" },
        { name: "Ris (Jasmin, kogt)", kcal: 130, brand: "Global" },
        { name: "Coca-Cola Zero", kcal: 0, brand: "The Coca-Cola Company" },
        { name: "Coca-Cola (Original)", kcal: 42, brand: "The Coca-Cola Company" },
        { name: "Hytteost 1.5%", kcal: 85, brand: "Arla" },
        { name: "Havregryn", kcal: 370, brand: "Oatmeal Global" },
        { name: "Æg (Hele, kogt)", kcal: 155, brand: "Standard" },
        { name: "Banan", kcal: 89, brand: "Frugt" },
        { name: "Æble", kcal: 52, brand: "Frugt" },
        { name: "Mandler", kcal: 579, brand: "Nødder" },
        { name: "Laks (Bagt)", kcal: 206, brand: "Fisk" },
        { name: "Protein Pulver (Valle)", kcal: 390, brand: "Bodylab" },
        { name: "Mælk (Letmælk)", kcal: 47, brand: "Arla" },
        { name: "Avocado", kcal: 160, brand: "Frugt" },
        { name: "Smør", kcal: 717, brand: "Lurpak" },
        { name: "Blandet Slik / Vingummi", kcal: 380, brand: "Haribo" },
        { name: "Romkugle", kcal: 390, brand: "Bager" }
    ];

    let state = JSON.parse(localStorage.getItem('compassState')) || {
        eaten: 0,
        dailyBudget: 1537,
        steps: 0,
        stars: 0,
        water: 0,
        weightHistory: [80, 78.5, 77, 75],
        isPremium: true,
        lang: 'dk'
    };

    let chart;
    let selectedGlobalFood = null;
    let computedAICalories = 0;

    function searchOfflineFood() {
        let query = document.getElementById('globalSearchInput').value.toLowerCase().trim();
        let resultsDiv = document.getElementById('searchResults');
        if (query.length < 1) { resultsDiv.innerHTML = ''; return; }
        resultsDiv.innerHTML = '';
        let matches = offlineFoodDatabase.filter(f => f.name.toLowerCase().includes(query));
        if (matches.length > 0) {
            matches.forEach(product => {
                let item = document.createElement('div');
                item.className = 'search-item';
                item.innerText = ${product.name} (${product.brand}) - ${product.kcal} kcal/100g;
                item.onclick = () => selectOfflineFood(product.name, product.kcal);
                resultsDiv.appendChild(item);
            });
        } else {
            resultsDiv.innerHTML = '<div class="search-item" style="color:#718093;">Ikke fundet. Brug manuel indtastning.</div>';
        }
    }

    function selectOfflineFood(name, kcalPer100g) {
        selectedGlobalFood = { name, kcalPer100g };
        document.getElementById('selectedFoodName').innerText = name;
        document.getElementById('selectedFoodKcal').innerText = kcalPer100g;
        document.getElementById('searchResults').innerHTML = '';
        document.getElementById('weightFactorBox').style.display = 'block';
    }

    function logOfflineFood() {
        let amount = parseFloat(document.getElementById('foodAmountInput').value);
        if (amount && selectedGlobalFood) {
            let totalKcal = Math.round((selectedGlobalFood.kcalPer100g / 100) * amount);
            state.eaten += totalKcal;
            alert(Logget: ${amount}g ${selectedGlobalFood.name} (${totalKcal} kcal));
            document.getElementById('weightFactorBox').style.display = 'none';
            document.getElementById('globalSearchInput').value = '';
            updateUI();
        }
    }

    function logManualFood() {
        let name = document.getElementById('manualName').value.trim() || "Manuelt måltid";
        let kcal = parseInt(document.getElementById('manualKcal').value);
        if (kcal) {
            state.eaten += kcal;
            alert(Gemt: ${name} (${kcal} kcal));
            document.getElementById('manualName').value = '';
            document.getElementById('manualKcal').value = '';
            document.getElementById('manualWeight').value = '';
            updateUI();
        }
    }

    function triggerLocalAIScan(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('scannedImagePreview').src = e.target.result;
                document.getElementById('previewContainer').style.display = 'block';
                let seed = file.size % 200;
                computedAICalories = 430 + seed; 
                state.eaten += computedAICalories;
                updateCoachTone(true);
                updateUI();
            }
            reader.readAsDataURL(file);
        }
    }

    function updateCoachTone(isPhotoScan = false) {
        let persona = document.getElementById('coachPersona').value;
        let speechBox = document.getElementById('coachSpeech');
        if (isPhotoScan) {
            if (persona === 'militær') {
                speechBox.innerText = LOKAL ANALYSE: Hånd-reference fundet. Tallerkenen rummer ca. ${computedAICalories} kcal. Afsted med dig, få nu nappet de skridt!;
            } else {
                speechBox.innerText = Hånd-metode scanning: Ud fra din hånds volumen vurderer jeg måltidet til ca. ${computedAICalories} kcal. Det ser super fornuftigt ud! ❤️;
            }
            return;
        }
        if (persona === 'militær') { speechBox.innerText = "Hver kalorie tæller offline som online!"; }
        else { speechBox.innerText = "Jeg gemmer alt på din telefon, så vi har styr på det hele sammen. ❤️"; }
    }

    function addSteps(num) { state.steps += num; state.stars += (num / 1000) * 50; updateUI(); }
    function toggleWater(num) { state.water = state.water === num ? num - 1 : num; updateUI(); }

    function runMifflin() {
        let w = parseFloat(document.getElementById('profWeight').value) || 80;
        let h = parseFloat(document.getElementById('profHeight').value) || 180;
        let a = parseInt(document.getElementById('profAge').value) || 32;
        let bmr = (10 * w) + (6.25 * h) - (5 * a) + 5; 
        state.dailyBudget = Math.round(bmr * 1.2);
        updateUI();
    }

    function syncWeightInput() {
        let w = parseFloat(document.getElementById('profWeight').value);
        if(w) { state.weightHistory[state.weightHistory.length - 1] = w; updateChart(); }
    }

    function updateUI() {
        document.getElementById('totalKcal').innerText = state.eaten;
        document.getElementById('budgetDisplay').innerText = state.dailyBudget;
        let left = state.dailyBudget - state.eaten;
        document.getElementById('leftDisplay').innerText = left;
        let pct = Math.min((state.eaten / state.dailyBudget) * 100, 100);
        document.getElementById('progressBar').style.width = pct + '%';
        document.getElementById('starDisplay').innerText = state.stars + " ⭐ (Skridt: " + state.steps + ")";
        for(let i=1; i<=4; i++) { document.getElementById('w'+i).classList.toggle('active', state.water >= i); }
        localStorage.setItem('compassState', JSON.stringify(state));
    }

    function updateChart() {
        const ctx = document.getElementById('weightChart').getContext('2d');
        if (chart) chart.destroy();
        chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Uge 1', 'Uge 2', 'Uge 3', 'Uge 4 (Nu)'],
                datasets: [
                    { label: 'Min Vægt (kg)', data: state.weightHistory, borderColor: '#4cd137', tension: 0.1, fill: false },
                    { label: 'Mål (63 kg)', data: [63, 63, 63, 63], borderColor: '#e1b12c', borderDash: [5, 5], fill: false }
                ]
            },
            options: { responsive: true, scales: { y: { min: 60, max: 90 } } }
        });
    }

    document.addEventListener("DOMContentLoaded", function() {
        let duration = 16 * 60 * 60 * 1000;
        setInterval(() => {
            let left = duration - (Date.now() % duration);
            document.getElementById('timer').innerText = new Date(left).toISOString().substr(11, 8);
        }, 1000);
    });

    updateUI();
    updateChart();
</script>

</body>
</html>
